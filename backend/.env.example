# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Database
DATABASE_URL=sqlite:./database.sqlite

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# PayFast (South Africa)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=your_passphrase
PAYFAST_SANDBOX=true

# Ozow
OZOW_SITE_CODE=your_site_code
OZOW_API_KEY=your_api_key
OZOW_PRIVATE_KEY=your_private_key
OZOW_SANDBOX=true

# African Bank Direct EFT
BANK_ACCOUNT_NAME=Your Company Name
BANK_ACCOUNT_NUMBER=1234567890
BANK_NAME=African Bank
BANK_BRANCH_CODE=123456

# AI Marketing (OpenAI)
OPENAI_API_KEY=your_openai_api_key

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Admin/Owner
OWNER_WALLET_ADDRESS=owner_bank_account_or_crypto
COMPANY_WALLET_ADDRESS=company_bank_account
